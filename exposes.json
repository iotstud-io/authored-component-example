{
    "name": "authored-component-example",
    "components": [
        {
            "name": "GenericTempSensor",
            "defaultExport": true,
            "description": "Generic temperature component for when a device does not expose the temperature unit type. Use the temperature_format setting to specify the unit type for the temperature value.",
            "capabilities": {
                "temperature": "required"
            },
            "css": [
                "css/climate.css"
            ],
            "settings": [
                {
                    "name": "temperature_format",
                    "label": "Temperature Format",
                    "description": "Set the display to Celsius or Fahrenheit.",
                    "default": "f",
                    "options": [
                        { "value": "c", "label": "Celsius" },
                        { "value": "f", "label": "Fahrenheit" }
                    ]
                }
            ]
        },
        {
            "name": "GenericClimateSensor",
            "defaultExport": true,
            "description": "Generic temperature/humidity component.",
            "capabilities": {
                "temp_celcius": "optional",
                "temp_fahrenheit": "optional",
                "humidity": "optional"
            },
            "css": [
                "css/climate.css"
            ],
            "settings": [
                {
                    "name": "temperature_format",
                    "label": "Temperature Format",
                    "description": "Choose between Celsius and Fahrenheit.",
                    "default": "f",
                    "options": [
                        { "value": "c", "label": "Celsius" },
                        { "value": "f", "label": "Fahrenheit" }
                    ]
                }
            ]
        },
        {
            "name": "OrgLocation",
            "defaultExport": true,
            "description": "Generic display of a location in the org hierarchy tree.",
            "capabilities": {},
            "settings": [
                {
                    "name": "show_room_level",
                    "label": "Show/Hide Unit Level of Org Location",
                    "description": "Toggle to show or hide the unit level of the Org Location.",
                    "default": false,
                    "options": [
                        { "value": false, "label": "Hide" },
                        { "value": true, "label": "Show" }
                    ]
                },
                {
                    "name": "size",
                    "label": "Choose a size of the Component",
                    "description": "Switches between different sizes for the component to display as.",
                    "default": "small",
                    "options": [
                        { "value": "small", "label": "Small" },
                        { "value": "medium", "label": "Medium" },
                        { "value": "large", "label": "Large" }
                    ]
                }
            ]
        },
        {
            "name": "CngSensor",
            "defaultExport": true,
            "description": "Generic display of a Compressed Natural Gas sensor.",
            "capabilities": {
                "cng": "optional"
            },
            "settings": []
        },
        {
            "name": "GenericThermostatSlider",
            "defaultExport": true,
            "description": "Generic display/controller of a Smart Thermostat.",
            "capabilities": {
                "temp_celcius": "optional",
                "temp_fahrenheit": "optional"
            },
            "settings": [
                {
                    "name": "temperature_format",
                    "label": "Temperature Format",
                    "description": "Choose between Celsius and Fahrenheit.",
                    "default": "f",
                    "options": [
                        { "value": "c", "label": "Celsius" },
                        { "value": "f", "label": "Fahrenheit" }
                    ]
                }
            ]
        },
        {
            "name": "GenericLightDimmer",
            "defaultExport": true,
            "description": "Generic display/controller of a Smart Light Dimmer.",
            "capabilities": {
                "brightness_percent": "required",
                "set_brightness": "required",
                "light_state": "optional",
                "set_light_state": "optional"
            },
            "settings": []
        },
        {
            "name": "GenericLeakDetector",
            "defaultExport": true,
            "description": "Generic display of a water leak detector.",
            "capabilities": {
                "water_detected": "optional"
            },
            "settings": []
        }
    ]
}
